## 9. Recursion Patterns for Strings

### Pattern 1: Process each character
```java
// Generate all subsequences
public static List<String> subsequences(String s) {
    List<String> result = new ArrayList<>();
    generateSubs(s, 0, new StringBuilder(), result);
    return result;
}

private static void generateSubs(String s, int idx, StringBuilder curr, List<String> res) {
    if (idx == s.length()) {
        res.add(curr.toString());
        return;
    }
    // Include current char
    curr.append(s.charAt(idx));
    generateSubs(s, idx + 1, curr, res);
    curr.deleteCharAt(curr.length() - 1);

    // Exclude current char
    generateSubs(s, idx + 1, curr, res);
}
```

### Pattern 2: Split into prefix + suffix
```java
// All permutations
public static List<String> permutations(String s) {
    List<String> result = new ArrayList<>();
    permHelper("", s, result);
    return result;
}

private static void permHelper(String prefix, String remaining, List<String> result) {
    if (remaining.isEmpty()) {
        result.add(prefix);
        return;
    }
    for (int i = 0; i < remaining.length(); i++) {
        permHelper(
            prefix + remaining.charAt(i),
            remaining.substring(0, i) + remaining.substring(i + 1),
            result
        );
    }
}
```

### Pattern 3: Reduce string size (top-down)
```java
// Recursive palindrome with memoization
public static boolean isPalindromeRecur(String s, int l, int r, Map<String, Boolean> memo) {
    if (l >= r) return true;
    String key = l + "," + r;
    if (memo.containsKey(key)) return memo.get(key);

    boolean result = s.charAt(l) == s.charAt(r)
        && isPalindromeRecur(s, l + 1, r - 1, memo);
    memo.put(key, result);
    return result;
}
```

### Pattern 4: Interleave strings (recursion + DP)
```java
public static boolean isInterleave(String s1, String s2, String s3,
                                    int i, int j, int k, Boolean[][] memo) {
    if (k == s3.length()) return i == s1.length() && j == s2.length();
    if (memo[i][j] != null) return memo[i][j];

    boolean res = false;
    if (i < s1.length() && s1.charAt(i) == s3.charAt(k))
        res = isInterleave(s1, s2, s3, i+1, j, k+1, memo);
    if (!res && j < s2.length() && s2.charAt(j) == s3.charAt(k))
        res = isInterleave(s1, s2, s3, i, j+1, k+1, memo);

    return memo[i][j] = res;
}
```

