## 14. Longest Repeating Substring

```java
// Binary Search + Rolling Hash
// Time: O(n log n) | Space: O(n)
public static String longestRepeatingSubstring(String s) {
    int n = s.length(), lo = 1, hi = n - 1;
    String result = "";

    while (lo <= hi) {
        int mid = (lo + hi) / 2;
        String candidate = search(s, mid);
        if (!candidate.isEmpty()) {
            result = candidate;
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    return result;
}

private static String search(String s, int len) {
    Set<Long> seen = new HashSet<>();
    long base = 26, mod = 1_000_000_007L;
    long hash = 0, power = 1;

    for (int i = 0; i < len; i++) {
        hash = (hash * base + s.charAt(i)) % mod;
        if (i > 0) power = power * base % mod;
    }
    seen.add(hash);

    for (int i = len; i < s.length(); i++) {
        hash = (hash - s.charAt(i - len) * power % mod + mod) % mod;
        hash = (hash * base + s.charAt(i)) % mod;
        if (!seen.add(hash)) return s.substring(i - len + 1, i + 1);
    }
    return "";
}
```

